meta {
  name: Admin Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/admin/login
  body: json
  auth: none
}

body:json {
  {
    "username": "admin",
    "password": "admin123"
  }
}

script:post-response {
  if (res.body.success && res.body.data.token) {
    bru.setEnvVar("authToken", res.body.data.token);
  }
}
