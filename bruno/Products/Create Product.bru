meta {
  name: Create Product
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/products
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "name": "New Product",
    "description": "Product description",
    "price": 29.99,
    "category": "smoothie",
    "image": "data:image/jpeg;base64,"
  }
}
